# Azure Blob Storage
CONEXION_AZURE=DefaultEndpointsProtocol=https;AccountName=XXXXXX;AccountKey=XXXXXX
AZURE_CONTAINER_NAME=tu-contenedor
AZURE_BLOB_NAME=spotify_wrapped_2025.csv

# Azure Data Lake Gen2
ADLS_ACCOUNT_NAME=tu-cuenta-adls
ADLS_CONTAINER_BRONZE=bronze
ADLS_CONTAINER_SILVER=silver
ADLS_CONTAINER_GOLD=gold

# Azure Synapse
SYNAPSE_WORKSPACE=tu-workspace
SYNAPSE_DATABASE=spotify_analytics
SYNAPSE_SERVER=tu-servidor.sql.azuresynapse.net
SYNAPSE_USER=admin
SYNAPSE_PASSWORD=XXXXXX

# Spotify API
SPOTIFY_CLIENT_ID=tu-client-id
SPOTIFY_CLIENT_SECRET=tu-client-secret

# Configuración general
LOG_LEVEL=INFO
ENVIRONMENT=dev